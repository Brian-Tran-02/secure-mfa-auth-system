{
  "compilerOptions": {
    "target": "ES2020",
    "module": "NodeNext",
    "rootDir": "./src",
    "outDir": "./dist",

    "strict": true,

    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,

    "moduleResolution": "nodenext",

    "skipLibCheck": true,

    "forceConsistentCasingInFileNames": true,

    "types": ["node"]
  },

  "include": ["src/**/*.ts", "src/**/*.d.ts"]
}